rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Company Profiles ---
    match /companies/{companyId} {
      allow get: if true;
      allow list: if false;
      allow create: if request.auth != null && request.auth.uid == companyId;
      allow update: if request.auth != null && request.auth.uid == companyId && resource != null;
      allow delete: if request.auth != null && request.auth.uid == companyId && resource != null;
    }

    // --- Invoices ---
    match /companies/{companyId}/invoices/{invoiceId} {
      allow get: if true;
      allow list: if request.auth != null && request.auth.uid == companyId;
      allow create: if request.auth != null && request.auth.uid == companyId && request.resource.data.companyId == companyId;
      allow update: if request.auth != null && request.auth.uid == companyId && resource != null && request.resource.data.companyId == companyId;
      allow delete: if request.auth != null && request.auth.uid == companyId && resource != null;
    }

    // --- Expenses ---
    match /companies/{companyId}/expenses/{expenseId} {
      allow get: if true;
      allow list: if request.auth != null && request.auth.uid == companyId;
      allow create: if request.auth != null && request.auth.uid == companyId && request.resource.data.companyId == companyId;
      allow update: if request.auth != null && request.auth.uid == companyId && resource != null && request.resource.data.companyId == companyId;
      allow delete: if request.auth != null && request.auth.uid == companyId && resource != null;
    }

    // --- Clients ---
    match /companies/{companyId}/clients/{clientId} {
      allow get: if true;
      allow list: if request.auth != null && request.auth.uid == companyId;
      allow create: if request.auth != null && request.auth.uid == companyId;
      allow update: if request.auth != null && request.auth.uid == companyId && resource != null;
      allow delete: if request.auth != null && request.auth.uid == companyId && resource != null;
    }

    // --- POS Products ---
    // Public catalog: anyone can read, authenticated users can write
    match /products/{productId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // --- POS Sales ---
    match /sales/{saleId} {
      allow read, write: if true;
    }
  }
}